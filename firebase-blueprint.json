{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with gamification stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin"] },
        "points": { "type": "number" },
        "streak": { "type": "number" },
        "lastActivity": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "Generated quiz from a document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "questions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "question": { "type": "string" },
              "options": { "type": "array", "items": { "type": "string" } },
              "correctAnswer": { "type": "string" },
              "type": { "type": "string", "enum": ["mcq", "true-false", "fill-in-the-blank"] }
            }
          }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "questions", "createdBy", "createdAt"]
    },
    "FlashcardSet": {
      "title": "FlashcardSet",
      "description": "Generated flashcards from a document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "cards": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "front": { "type": "string" },
              "back": { "type": "string" }
            }
          }
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "cards", "createdBy", "createdAt"]
    },
    "Performance": {
      "title": "Performance",
      "description": "User performance on a quiz",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "quizId": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "quizId", "score", "totalQuestions", "completedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Generated quizzes"
    },
    "/flashcardSets/{setId}": {
      "schema": "FlashcardSet",
      "description": "Generated flashcard sets"
    },
    "/performances/{perfId}": {
      "schema": "Performance",
      "description": "User performance records"
    }
  }
}
