{
  "version": 2,
  "builds": [
    {
      "src": "backend/studybuddy_api/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm install && npm run build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/studybuddy_api/wsgi.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/backend/studybuddy_api/wsgi.py"
    },
    {
      "src": "/accounts/(.*)",
      "dest": "/backend/studybuddy_api/wsgi.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/backend/studybuddy_api/wsgi.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/index.html"
    }
  ]
}