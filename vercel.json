{
  "version": 2,
  "builds": [
    {
      "src": "backend/studybuddy_api/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "buildCommand": "npm install && npm run build"
      }
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/studybuddy_api/wsgi.py" },
    { "source": "/admin/:path*", "destination": "/backend/studybuddy_api/wsgi.py" },
    { "source": "/accounts/:path*", "destination": "/backend/studybuddy_api/wsgi.py" },
    { "source": "/static/:path*", "destination": "/backend/studybuddy_api/wsgi.py" },
    { "source": "/:path*", "destination": "/frontend/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ]
}
